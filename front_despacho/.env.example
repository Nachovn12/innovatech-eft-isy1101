# Copia este archivo como .env.local para desarrollo local con docker-compose
# (Vite carga .env.local automáticamente y NO se sube a git).
#
# En producción (AWS), estos valores se inyectan como variables del build
# en el pipeline de GitHub Actions -- ver .github/workflows/*.yml

# URL del backend de Ventas (sin / al final)
VITE_API_VENTAS_URL=http://localhost:8080

# URL del backend de Despachos (sin / al final)
VITE_API_DESPACHOS_URL=http://localhost:8081
