{
  "family": "innovatech-despachos",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::112483261942:role/LabRole",
  "taskRoleArn": "arn:aws:iam::112483261942:role/LabRole",
  "containerDefinitions": [
    {
      "name": "innovatech-despachos",
      "image": "112483261942.dkr.ecr.us-east-1.amazonaws.com/innovatech-despachos:latest",
      "portMappings": [{"containerPort": 8081, "protocol": "tcp"}],
      "environment": [
        {"name": "DB_ENDPOINT", "value": "innovatech-db.capzpky5qmfb.us-east-1.rds.amazonaws.com"},
        {"name": "DB_PORT", "value": "3306"},
        {"name": "DB_NAME", "value": "despachos_db"},
        {"name": "DB_USERNAME", "value": "admin"}
      ],
      "secrets": [
        {"name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:112483261942:secret:innovatech/rds/db-password-zdMNGj:password::"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/innovatech-despachos",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
